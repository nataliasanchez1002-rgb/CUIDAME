
#---------------------pANTALLAS----------------------------

ScreenManager:
    LoginScreen:
        name: "login"
    RegisterScreen:
        name: "register"
    HomeScreen:
        name: "home"
    GameScreen:
        name: "game"
    BodyScreen:
        name: "Mybody"
    ChatScreen:
        name: "Chatbot"
    MemoryScreen:
        name: "MemoryGame"

#------------------------------------------------------------

<LoginScreen>:
    FloatLayout:
        # FONDO
        Image:
            source: "Imagenes/Sign In.png"
            size_hint: 1, 1
            pos_hint: {"center_x": 0.5, "center_y": 0.5}
            allow_stretch: True
            keep_ratio: False

        BoxLayout:
            orientation: 'vertical'
            size_hint: .85, None
            height: self.minimum_height
            pos_hint: {'center_x': .5, 'center_y': .32} 
            spacing: "25dp" # Aumentamos el espacio para que el helper text no choque
            padding: "10dp"

            # CAMPO USUARIO
            MDTextField:
                id: user
                hint_text: "Usuario"
                icon_right: "account"
                helper_text: "Pon tu usuario"
                helper_text_mode: "on_focus" # Cambia a "persistent" si quieres verlo siempre
                mode: "round"
                fill_color_normal: 0.9, 0.9, 0.9, 1 # Un gris ligero para que resalte el texto crema
                line_color_normal: 1, 0.91, 0.59, 1
                line_color_focus: 1, 0.91, 0.59, 1
                text_color_focus: 1, 0.91, 0.59, 1
                hint_text_color_focus: 1, 0.91, 0.59, 1
                helper_text_color_focus: 1, 0.8, 0.4, 1 # Color un poco más oscuro para legibilidad

            # CAMPO CONTRASEÑA
            MDTextField:
                id: psswd
                hint_text: "Contraseña"
                helper_text: "Coloca tu contraseña"
                helper_text_mode: "on_focus"
                password: True
                icon_right: "eye-off"
                mode: "round"
                fill_color_normal: 0.9, 0.9, 0.9, 1
                line_color_normal: 1, 0.91, 0.59, 1
                line_color_focus: 1, 0.91, 0.59, 1
                text_color_focus: 1, 0.91, 0.59, 1
                helper_text_color_focus: 1, 0.8, 0.4, 1
                on_icon_right: 
                    self.password = not self.password
                    self.icon_right = "eye" if self.icon_right == "eye-off" else "eye-off"

            MDLabel:
                text: root.mensaje
                halign: "center"
                size_hint_y: None
                height: "20dp"
                theme_text_color: "Error"
                font_style: "Caption"

            MDFillRoundFlatButton:
                text: "ENTRAR"
                font_name: "Fonts/Simply Olive.ttf"
                font_size: "22sp"
                size_hint_x: 1
                md_bg_color: 1, 0.91, 0.59, 1
                text_color: 0.96, 0.66, 0.71, 1
                on_release: root.login(user.text, psswd.text)

            MDFlatButton:
                text: "¿No tienes cuenta? Regístrate"
                font_name: "Fonts/Simply Olive.ttf"
                font_size: "16sp"
                pos_hint: {'center_x': .5}
                theme_text_color: "Custom"
                text_color: 1, 0.91, 0.59, 1
                on_release: app.root.current = "register"

#----------------------------------------------------------------
<RegisterScreen>:
    FloatLayout:
        # FONDO
        Image:
            source: "Imagenes/Sign Up.png"
            size_hint: 1, 1
            pos_hint: {"center_x": 0.5, "center_y": 0.5}
            allow_stretch: True
            keep_ratio: False

        # CONTENEDOR PRINCIPAL
        BoxLayout:
            orientation: 'vertical'
            size_hint: .85, None
            height: self.minimum_height
            pos_hint: {'center_x': .5, 'center_y': .35} # Bajamos la interfaz
            spacing: "25dp" # Espacio amplio para los textos de apoyo

            # NUEVO USUARIO
            MDTextField:
                id: new_user
                hint_text: "Nuevo Usuario"
                helper_text: "Elige un nombre de usuario único"
                helper_text_mode: "on_focus"
                icon_right: "account-plus"
                mode: "round"
                # Colores adaptados a tu paleta (Azul claro/crema)
                line_color_normal: 0.73, 0.84, 0.85, 1
                line_color_focus: 0.73, 0.84, 0.85, 1
                text_color_focus: 0.73, 0.84, 0.85, 1
                hint_text_color_focus: 0.73, 0.84, 0.85, 1
                helper_text_color_focus: 0.73, 0.84, 0.85, 1

            # NUEVA CONTRASEÑA
            MDTextField:
                id: new_password
                hint_text: "Nueva Contraseña"
                helper_text: "Mínimo 6 caracteres"
                helper_text_mode: "on_focus"
                password: True
                icon_right: "eye-off"
                mode: "round"
                line_color_normal: 0.73, 0.84, 0.85, 1
                line_color_focus: 0.73, 0.84, 0.85, 1
                text_color_focus: 0.73, 0.84, 0.85, 1
                helper_text_color_focus: 0.73, 0.84, 0.85, 1
                on_icon_right: 
                    self.password = not self.password
                    self.icon_right = "eye" if self.icon_right == "eye-off" else "eye-off"

            MDLabel:
                text: root.mensaje
                halign: "center"
                size_hint_y: None
                height: "20dp"
                theme_text_color: "Error"
                font_style: "Caption"

            # BOTÓN GUARDAR
            MDFillRoundFlatButton:
                text: "GUARDAR CUENTA"
                size_hint_x: 1
                font_name: "Fonts/Simply Olive.ttf"
                font_size: "22sp"
                md_bg_color: 1.00, 0.91, 0.59, 1
                text_color: 0.96, 0.66, 0.71, 1
                on_release: root.register(new_user.text, new_password.text)

        # BOTÓN VOLVER 
        MDTextButton:
            text: "Volver al Login"
            font_size: "20sp"
            font_name: "Fonts/Simply Olive.ttf"
            theme_text_color: "Custom"
            text_color: 0.96, 0.66, 0.71, 1
            pos_hint: {"center_x": .5, "y": 0.05}
            on_release: root.manager.current = "login"
#------------------------------------------------------------------
<HomeScreen>:
    MDScreen:

        MDBottomNavigation: #BARRA DE NAVEGACION 
            panel_color: 0.88, 0.94, 0.96, 1
            text_color_active: 0.55, 0.70, 0.40, 1
            text_color_normal: 0.5, 0.5, 0.5, 1
            elevation: 8

            MDBottomNavigationItem:
                name: "juegos"
                icon: "gamepad-variant"

                FloatLayout:
                    Image: 
                        source: "Imagenes/Home.png"
                        size_hint: 1, 1
                        allow_stretch: True
                        keep_ratio: False

                    ImageButton:
                        source: "Imagenes/Boton1.png"
                        size_hint: None, None
                        size: 450, 300
                        pos_hint: {"center_x": 0.5, "center_y": 0.65}
                        on_release: root.manager.current = "game"
                        
                    ImageButton:
                        source: "Imagenes/Boton 2.png"
                        size_hint: None, None
                        size: 450, 300
                        pos_hint: {"center_x": 0.5, "center_y": 0.39}
                        on_release: root.manager.current = "Mybody"

                    ImageButton:
                        source: "Imagenes/Boton3.png"
                        size_hint: None, None
                        size: 450, 300
                        pos_hint: {"center_x": 0.5, "center_y": 0.13}
                        on_release: root.manager.current = "MemoryGame"

            MDBottomNavigationItem:
                name: "chat"
                icon: "chat"
                on_tab_press: root.manager.current = "Chatbot"
#-------------------------------------

<GameScreen>:
    FloatLayout:

        Image: #FONDO 
            source: "imagenes/cofres.png"
            allow_stretch: True
            keep_ratio: False

        ImageButton: #COFRE BUENO
            id: bueno
            source: "imagenes/cofre_bueno.png"
            size_hint: .75, .5
            pos_hint: {"x": -.12, "y": .12}

        ImageButton: #COFRE MALO
            id: malo
            source: "imagenes/cofre_malo.png"
            size_hint: .75, .5
            pos_hint: {"right": 1.12, "y": .12}

        DraggableSecret:
            id: secret_label
            size_hint: None, None
            size: "240dp", "140dp"
            pos: 70, 400

            halign: "center"
            valign: "middle"
            text_size: self.width - 30, self.height - 30

            font_name: "Fonts/Simply Olive.ttf"
            font_size: "20sp"
            bold: True

            color: 0.35, 0.2, 0.1, 1
            padding: 15, 15

            drag_rectangle: self.x, self.y, self.width, self.height
            drag_timeout: 10000000
            drag_distance: 0

            on_touch_up:
                root.verificar_colision()

            canvas.before:
                Rectangle:
                    pos: self.pos
                    size: self.size
                    source: "imagenes/pergamino.png"

        MDLabel: #RESULTADO DEL JUEGO
            id: resultado
            text: ""
            halign: "center"
            valign: "middle"
            pos_hint: {"center_x": .5, "center_y": .5}
            font_size: "38sp"
            bold: True
            theme_text_color: "Custom"
            text_color: 0.635, 0.823, 1, 1
            outline_width: 1.5
            outline_color: 1, 1, 1, 1

        MDFillRoundFlatButton: #BOTON VOLVER
            text: "Volver"
            font_name: "Fonts/Simply Olive.ttf"
            font_size: "20sp"
            pos_hint: {"center_x": .5, "y": .08}
            size_hint_x: .4
            md_bg_color: 0.635, 0.823, 1, 1
            on_release:
                root.manager.current = "home"

        Label:
            id: score_label #PUNTAJE
            text: "Puntos: 0"
            halign: "center"
            valign: "middle"
            
            pos_hint: {"center_x": .5, "y": .15}
            size_hint: None, None
            size: "200dp", "60dp"
            
            font_size: "24sp"
            bold: True
            color: 0.3, 0.2, 0.1, 1  
            
            opacity: 0  

            canvas.before:
                Color:
                    rgba: 0, 0, 0, 0.1
                RoundedRectangle:
                    pos: self.x + 2, self.y - 2
                    size: self.size
                    radius: [30,]
                
                Color:
                    rgba: 1, 0.96, 0.88, 1 
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [30,]
                
                Color:
                    rgba: 0.7, 0.8, 0.9, 1  
                Line:
                    width: 1.5
                    rounded_rectangle: (self.x, self.y, self.width, self.height, 30)


#------------------------------------------------------------------


<BodyScreen>:
    BoxLayout:
        orientation: "vertical"

        Image:
            id: camera_view

        MDFillRoundFlatButton:
            text: "Regresar"
            font_size: "22sp"
            size_hint: 0.7, None
            height: "55dp"
            pos_hint: {"center_x": 0.5}

            md_bg_color: 0.4, 0.8, 1, 1   
            text_color: 1, 1, 1, 1

            radius: [30, 30, 30, 30]

            on_release:
                root.manager.current = "home"

#------------------------------------------------------------------


<MemoryScreen>:
    
    Image: #FONDO
        source: "Imagenes/Memory.png" 
        allow_stretch: True
        keep_ratio: False

    MDBoxLayout:
        orientation: 'vertical'
        padding: "15dp"
        spacing: "10dp"

       
        MDBoxLayout:
            size_hint_y: None
            height: "90dp"
            orientation: 'vertical'
            MDLabel:
                text: root.mensaje
                halign: "center"
                font_style: "H5"
                bold: True
                theme_text_color: "Custom"
                text_color: 0.9, 0.5, 0.6, 1 


            MDLabel:  #TIEMPO Y PUNTOS 
                text: "Tiempo: {}s | Puntos: {}".format(int(root.tiempo), int(root.puntos))
                halign: "center"
                font_style: "Caption"
                theme_text_color: "Hint"

        
        MDAnchorLayout: #TABLERO
            size_hint_y: 1
            MDGridLayout:
                id: grid
                cols: 2 
                spacing: "15dp"
                padding: "10dp"
                size_hint: None, None
                width: root.width * 0.8 
                height: self.minimum_height
                row_default_height: (self.width - self.spacing[0]) / 2
                row_force_default: True

       
        MDAnchorLayout: #BOTON VOLVER
            size_hint_y: None
            height: "80dp"
            padding: [0, 0, 0, "10dp"]
            MDFillRoundFlatButton:
                text: "VOLVER"
                font_size: "18sp"
                md_bg_color: 0.9, 0.5, 0.6, 1
                size_hint_x: 0.8
                on_press: root.manager.current = "home"

#------------------------------------------------------------------

<ChatScreen>:
    FloatLayout:

        Image: #FONDO
            source: "Imagenes/FondoChat.png"
            allow_stretch: True
            keep_ratio: False

        BoxLayout:
            canvas.before:
                Color:
                    rgba: 1, 1, 1, 0.2
                Rectangle:
                    pos: self.pos
                    size: self.size

        MDBoxLayout:
            orientation: "vertical"
            md_bg_color: 0, 0, 0, 0

            # ENCABEZADO
            MDBoxLayout:
                size_hint_y: None
                height: "80dp"
                padding: "10dp"

                MDLabel:
                    text: "Tu espacio seguro"
                    font_size: "30sp"
                    halign: "center"
                    font_style: "H6"
                    theme_text_color: "Custom"
                    text_color: 1, 1, 1, 1

            # CHAT
            ScrollView:
                do_scroll_x: False

                MDBoxLayout:
                    id: chat_box
                    orientation: "vertical"
                    size_hint_y: None
                    height: self.minimum_height
                    padding: "15dp"
                    spacing: "12dp"

            # PANEL INFERIOR
            MDCard:
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height   
                padding: "15dp"
                spacing: "12dp"
                radius: [25, 25, 0, 0]
                elevation: 4
                md_bg_color: 1, 1, 1, 0.95

                GridLayout:
                    id: botones_box
                    cols: 2
                    spacing: "12dp"
                    size_hint_y: None
                    height: self.minimum_height  

                # INPUT TEXTO
                MDTextField:
                    id: input_usuario
                    hint_text: "Escribe lo que quieras"
                    mode: "round"
                    size_hint_y: None               
                    height: "50dp" if root.modo_texto else 0
                    opacity: 1 if root.modo_texto else 0
                    disabled: not root.modo_texto

                # BOTÓN VOLVER
                MDBoxLayout:
                    orientation: "horizontal"
                    spacing: "10dp"
                    size_hint_y: None
                    height: "45dp"

                    MDFillRoundFlatButton:
                        text: "Volver"
                        md_bg_color: 0.5, 0.5, 0.5, 1
                        on_release:
                            root.manager.current = "home"